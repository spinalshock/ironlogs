{
  "name": "ironlogs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ironlogs/web dev",
    "build": "pnpm --filter @ironlogs/web build",
    "lint": "pnpm --filter @ironlogs/web lint",
    "preview": "pnpm --filter @ironlogs/web preview",
    "dev:all": "turbo dev",
    "build:all": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@9.15.0",
  "overrides": {
    "serialize-javascript": "^7.0.4"
  }
}
